# Application
NODE_ENV=development
PORT=3000
AUTO_SEED=true

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=stms
DB_SSL=false
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=1d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=stms

# CORS (comma-separated origins for production)
CORS_ORIGINS=http://localhost:3001

# ═══════════════════════════════════════════════════════════
# FET Engine Configuration
# ═══════════════════════════════════════════════════════════
FET_DOCKER_IMAGE=nbk-ems/fet:6.2.7
FET_CPU_LIMIT=2
FET_MEMORY_LIMIT=2g
FET_DEFAULT_TIMEOUT_SECONDS=300
FET_MAX_RETRIES=3
FET_RETRY_BASE_DELAY_MS=1000

# ═══════════════════════════════════════════════════════════
# Generation Queue Configuration (BullMQ)
# ═══════════════════════════════════════════════════════════
GENERATION_QUEUE_CONCURRENCY=2
GENERATION_QUEUE_PER_SCHOOL_LIMIT=1
